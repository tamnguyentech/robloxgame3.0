local sellModeButton = shopSellBar:FindFirstChild("SellModeButton")
local selectionLabel = shopSellBar:FindFirstChild("SelectionLabel")
local sellSelectedButton = shopSellBar:FindFirstChild("SellSelectedButton")

local function refreshSellControls()
	local selectedCount = selectedSellCountValue.Value
	local selectedCoins = selectedSellCoinsValue.Value

	if selectionLabel and selectionLabel:IsA("TextLabel") then
		selectionLabel.Text = string.format("Selected: %d cards (%d coins)", selectedCount, selectedCoins)
	end

	if sellModeButton and sellModeButton:IsA("TextButton") then
		if sellModeEnabledValue.Value then
			sellModeButton.Text = "Sell: ON"
			sellModeButton.BackgroundColor3 = Color3.fromRGB(35, 130, 60)
		else
			sellModeButton.Text = "Sell: OFF"
			sellModeButton.BackgroundColor3 = Color3.fromRGB(90, 70, 32)
		end
	end

	if sellSelectedButton and sellSelectedButton:IsA("TextButton") then
		local canSell = sellModeEnabledValue.Value and selectedCount > 0
		sellSelectedButton.Active = canSell
		sellSelectedButton.AutoButtonColor = canSell
		sellSelectedButton.BackgroundColor3 = canSell and Color3.fromRGB(46, 118, 62) or Color3.fromRGB(62, 74, 66)
	end
end

if sellModeButton and sellModeButton:IsA("TextButton") then
	sellModeButton.MouseButton1Click:Connect(function()
		sellModeEnabledValue.Value = not sellModeEnabledValue.Value
		refreshSellControls()
	end)
end

if sellSelectedButton and sellSelectedButton:IsA("TextButton") then
	sellSelectedButton.MouseButton1Click:Connect(function()
		if not sellModeEnabledValue.Value or selectedSellCountValue.Value <= 0 then
			return
		end
		confirmSellSelectionEvent:Fire()
	end)
end

selectedSellCountValue:GetPropertyChangedSignal("Value"):Connect(refreshSellControls)
