refreshSellControls()

local function setUiVisible(isVisible)
	local itemsFrame = mainUI:FindFirstChild("ItemsFrame")
	local boosterPacksFrame = mainUI:FindFirstChild("BoosterPacksFrame")
	local tabBar = mainUI:FindFirstChild("InventoryTabBar")

	combatDeckFrame.Visible = isVisible

	if not isVisible then
		inventoryFrame.Visible = false
		if itemsFrame then
			itemsFrame.Visible = false
		end
		if boosterPacksFrame then
			boosterPacksFrame.Visible = false
		end
		if tabBar then
			tabBar.Visible = false
		end
		sortToggleButton.Visible = false
		sellModeEnabledValue.Value = false
		return
	end

	-- Opening defaults to Cards tab content.
	inventoryFrame.Visible = true
	if itemsFrame then
		itemsFrame.Visible = false
	end
	if boosterPacksFrame then
		boosterPacksFrame.Visible = false
	end
	if tabBar then
		tabBar.Visible = true
	end
	sortToggleButton.Visible = true
end

