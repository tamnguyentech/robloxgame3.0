local function showShopCardPreview(cardId)
	if not hoverPreview then
		return
	end
	local data = CardDatabase.GetCardData(cardId)
	if not data then
		return
	end
	hoverPreview.Show(cardId, data, getPreviewRarityColor(data.Rarity))
end

local function hideShopCardPreview()
	if hoverPreview then
		hoverPreview.Hide(0.04)
	end
end

