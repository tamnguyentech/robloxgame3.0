		return
	end
	tabBar:GetPropertyChangedSignal("Position"):Connect(layoutTogglesByTabBar)
	tabBar:GetPropertyChangedSignal("Size"):Connect(layoutTogglesByTabBar)
	tabBar:GetPropertyChangedSignal("Visible"):Connect(layoutTogglesByTabBar)
end

