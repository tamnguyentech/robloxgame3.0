local function getCardCount(card)
	if card and card:FindFirstChild("NumberLabel") then
		return tonumber(card.NumberLabel.Text) or 1
	end
	return 1
end

local function getCardAttack(card)
	if not card then
		return 0
	end
	local data = CardDatabase.GetCardData(card.Name)
	if data and type(data.Attack) == "number" then
		return data.Attack
	end
	if card:FindFirstChild("AttackLabel") then
		return tonumber(card.AttackLabel.Text) or 0
	end
	return 0
end

local rarityRank = {
	Common = 1,
	Uncommon = 2,
	Rare = 3,
	Epic = 4,
	Legendary = 5,
	God = 6,
	Transcendent = 7,
}

local sortModes = {
	{key = "ATK", label = "Sort:ATK"},
	{key = "COUNT", label = "Sort:CNT"},
	{key = "RARITY", label = "Sort:RAR"},
}
local currentSortModeIndex = 1

local function setSortButtonLabel(text)
	local label = sortToggleButton:FindFirstChild("Label")
	if label and label:IsA("TextLabel") then
		label.Text = text
	end
end

local function getCardRarityRank(card)
	if not card then
		return 0
	end
	local data = CardDatabase.GetCardData(card.Name)
	local rarity = (data and data.Rarity) or "Common"
	return rarityRank[rarity] or 1
end

local function sortInventoryByMode(modeKey)
	local cards = {}
	for _, child in ipairs(inventoryFrame:GetChildren()) do
		if child:IsA("GuiButton") then
			table.insert(cards, child)
		end
	end

	table.sort(cards, function(a, b)
		if modeKey == "COUNT" then
			local countA, countB = getCardCount(a), getCardCount(b)
			if countA ~= countB then
				return countA > countB
			end
			local atkA, atkB = getCardAttack(a), getCardAttack(b)
			if atkA ~= atkB then
				return atkA > atkB
			end
		elseif modeKey == "RARITY" then
			local rarityA, rarityB = getCardRarityRank(a), getCardRarityRank(b)
			if rarityA ~= rarityB then
				return rarityA > rarityB
			end
			local atkA, atkB = getCardAttack(a), getCardAttack(b)
			if atkA ~= atkB then
				return atkA > atkB
			end
		else
			local atkA, atkB = getCardAttack(a), getCardAttack(b)
			if atkA ~= atkB then
				return atkA > atkB
			end
			local countA, countB = getCardCount(a), getCardCount(b)
			if countA ~= countB then
				return countA > countB
			end
		end
		return a.Name < b.Name
	end)

	for index, card in ipairs(cards) do
		card.LayoutOrder = index
	end
end

setSortButtonLabel(sortModes[currentSortModeIndex].label)

inventoryToggleButton.MouseButton1Click:Connect(function()
	local itemsFrame = mainUI:FindFirstChild("ItemsFrame")
	local boosterPacksFrame = mainUI:FindFirstChild("BoosterPacksFrame")

	local currentlyOpen =
		inventoryFrame.Visible or
		combatDeckFrame.Visible or
		(itemsFrame and itemsFrame.Visible) or
		(boosterPacksFrame and boosterPacksFrame.Visible)

	local newState = not currentlyOpen
	setUiVisible(newState)

	-- If we just opened the UI, ensure the layout is actually inside the frames
	if newState then
		for _, frame in pairs({inventoryFrame, combatDeckFrame}) do
			local layout = frame:FindFirstChildOfClass("UIListLayout") or frame:FindFirstChildOfClass("UIGridLayout")
			-- Ensure the layout is inside the frame if it was previously removed
			if layout and layout.Parent == nil then
				layout.Parent = frame
			end
		end
	end
end)

sortToggleButton.MouseButton1Click:Connect(function()
	currentSortModeIndex += 1
	if currentSortModeIndex > #sortModes then
		currentSortModeIndex = 1
	end
	local mode = sortModes[currentSortModeIndex]
	setSortButtonLabel(mode.label)
	sortInventoryByMode(mode.key)
end)

